// 1. Load your specific geometry asset
var geometry = ee.FeatureCollection("projects/ee-mohammadoney/assets/fullbayofbengal");
Map.centerObject(geometry, 5);

// 2. Parameters 
var startYear = 1985;
var endYear = 2025; 
var years = ee.List.sequence(startYear, endYear);
var months = ee.List.sequence(1, 12);

// 3. Load Dataset
var oisst = ee.ImageCollection("NOAA/CDR/OISST/V2_1").select('sst');

// 4. Create Monthly Median Collection with Scaling
var monthlyComposites = years.map(function(y) {
  return months.map(function(m) {
    var monthlyMedian = oisst
      .filter(ee.Filter.calendarRange(y, y, 'year'))
      .filter(ee.Filter.calendarRange(m, m, 'month'))
      .median()
      // APPLY SCALING: Multiply by 0.01 to get actual Celsius
      .multiply(0.01) 
      .set('year', y)
      .set('month', m)
      .set('month_index', ee.Number(y).subtract(startYear).multiply(12).add(m).subtract(1));
    
    // Add Longitude and Latitude bands
    var coords = ee.Image.pixelLonLat();
    return monthlyMedian.addBands(coords).rename(['sst', 'longitude', 'latitude']).clip(geometry);
  });
}).flatten();

var monthlyCol = ee.ImageCollection.fromImages(monthlyComposites);

// 5. Sampling Pixels
var samplePoints = monthlyCol.map(function(img) {
  var year = img.get('year');
  var month = img.get('month');
  var monthIdx = img.get('month_index');
  
  return img.sample({
    region: geometry,
    scale: 27830,
    geometries: false 
  }).map(function(f) {
    return f.set({
      'year': year,
      'month': month,
      'month_index': monthIdx
    });
  });
}).flatten();

// 6. Export to Google Drive
Export.table.toDrive({
  collection: samplePoints,
  description: 'BoB_SST_1985_2025',
  fileFormat: 'CSV',
  // Re-ordering selectors for better CSV readability
  selectors: ['longitude', 'latitude', 'month_index', 'sst', 'year', 'month']
});

# Analysis Begins


import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from statsmodels.tsa.seasonal import STL
import pymannkendall as mk
from scipy.stats import theilslopes
import warnings

warnings.filterwarnings('ignore')

# 1. LOAD DATA
path = '/content/drive/MyDrive/earthengine/BoB_SST_41Years_Scaled_1985_2025.csv'
df = pd.read_csv(path)

# --- PHASE 2: CLIMATOLOGY & CHARACTERIZATION ---
climatology = df.groupby(['latitude', 'longitude'])['sst'].mean().reset_index()
ts_avg = df.groupby(['year', 'month'])['sst'].mean().reset_index()
ts_avg['date'] = pd.to_datetime(ts_avg[['year', 'month']].assign(day=1))
ts_avg = ts_avg.sort_values('date').set_index('date')
stl = STL(ts_avg['sst'], period=12, robust=True).fit()

# Plotting Climatology & STL
fig, ax = plt.subplots(1, 2, figsize=(18, 6))
pivot_map = climatology.pivot(index='latitude', columns='longitude', values='sst')
sns.heatmap(pivot_map, cmap='magma', ax=ax[0], xticklabels=False, yticklabels=False, cbar_kws={'label': 'Mean SST (°C)'})
ax[0].set_title('Long-term Climatology (1985-2025)')
ax[0].invert_yaxis()

ax[1].plot(ts_avg.index, ts_avg['sst'], color='lightgray', alpha=0.5, label='Monthly Data')
ax[1].plot(ts_avg.index, stl.trend, color='red', linewidth=2, label='STL Trend Component')
ax[1].set_title('STL Decomposition (Climate Signal Isolation)')
ax[1].legend()
plt.show()

# --- PHASE 3: TREND & MAGNITUDE (Yue & Wang 2004) ---
sst_values = ts_avg['sst'].values
# Switch to Yue and Wang to fix the 'nan' issue
yw_res = mk.yue_wang_modification_test(sst_values)
slope_dec = yw_res.slope * 12 * 10

def get_spatial_yw(group):
    # Apply Yue & Wang pixel-wise
    res = mk.yue_wang_modification_test(group['sst'].values)
    return pd.Series({'p_val': res.p, 'slope': res.slope * 12 * 10})

spatial_stats = df.groupby(['latitude', 'longitude']).apply(get_spatial_yw).reset_index()

# Plotting Significance Map
plt.figure(figsize=(10, 8))
sig_map = spatial_stats.copy()
sig_map.loc[sig_map['p_val'] > 0.05, 'slope'] = np.nan
pivot_sig = sig_map.pivot(index='latitude', columns='longitude', values='slope')
sns.heatmap(pivot_sig, cmap='RdYlBu_r', center=0, xticklabels=False, yticklabels=False, cbar_kws={'label': 'Warming Rate (°C/Decade)'})
plt.title(f'Significant Trends (Yue & Wang, p < 0.05)\nRegional Warming: {slope_dec:.3f}°C/decade')
plt.gca().invert_yaxis()
plt.show()


# ---------------------------------------------------------
# PHASE 4: EXTREMES & VARIABILITY
# ---------------------------------------------------------
basin_mean = ts_avg['sst'].mean()
basin_std = ts_avg['sst'].std()
ts_avg['anomaly'] = (ts_avg['sst'] - basin_mean) / basin_std

threshold = ts_avg['sst'].quantile(0.90)
ts_avg['is_extreme'] = ts_avg['sst'] > threshold
extreme_freq = ts_avg.groupby('year')['is_extreme'].sum()

fig, ax = plt.subplots(1, 2, figsize=(18, 5))
ax[0].bar(ts_avg.index, ts_avg['anomaly'],
          color=(ts_avg['anomaly'] > 0).map({True: 'salmon', False: 'skyblue'}), width=20)
ax[0].axhline(0, color='black', lw=1)
ax[0].set_title('Standardized Anomalies (Z-Score)')

ax[1].plot(extreme_freq.index, extreme_freq.values, marker='s', color='darkred', linestyle='--')
ax[1].set_title('Extreme Event Frequency (Months > 90th Pctl)')
ax[1].set_ylabel('Count of Months')
plt.show()


# ---------------------------------------------------------
# PHASE 5: ROBUSTNESS & SENSITIVITY
# ---------------------------------------------------------
unique_years = ts_avg.index.year.unique()
jackknife_slopes = []
for yr in unique_years:
    leave_one_out = ts_avg[ts_avg.index.year != yr]['sst'].values
    jk_res = mk.hamed_rao_modification_test(leave_one_out)
    jackknife_slopes.append(jk_res.slope * 12 * 10)

res_theil = theilslopes(sst_values, alpha=0.95)
lo_ci, hi_ci = res_theil[2] * 120, res_theil[3] * 120

plt.figure(figsize=(10, 5))
sns.histplot(jackknife_slopes, kde=True, color='green')
plt.axvline(slope_dec, color='red', label='Full Dataset Slope')
plt.title('Jackknife Sensitivity (Is the trend stable?)')
plt.xlabel('Decadal Slope (°C/decade)')
plt.legend()
plt.show()

print(f"\n--- MANUSCRIPT SUMMARY STATISTICS ---")
print(f"Statistical Method: Yue and Wang (2004) Modified Mann-Kendall")
print(f"Decadal Trend: {slope_dec:.4f} °C/decade")
print(f"95% Confidence Interval: [{lo_ci:.4f} to {hi_ci:.4f}]")
print(f"Yue-Wang P-Value: {yw_res.p:.5f}")
print(f"Basin Variance (StdDev): {ts_avg['sst'].std():.4f} °C")

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.metrics import mean_squared_error, r2_score
from scipy.stats import pearsonr
from statsmodels.graphics.tsaplots import plot_acf
import statsmodels.api as sm

# 1. Load Datasets
# Replace these paths if you are running locally or change the drive mounting point
oisst_path = '/content/drive/MyDrive/earthengine/BoB_SST_41Years_Scaled_1985_2025.csv'


df_oisst = pd.read_csv(oisst_path)



# ---------------------------------------------------------
# STEP 1: Data Gap Assessment
# ---------------------------------------------------------
print("\n--- Step 1: Data Gap Assessment ---")

# Calculate max pixels found in a single month (assumed as 100% coverage)
max_pixels = df_oisst.groupby(['year', 'month']).size().max()
monthly_counts = df_oisst.groupby(['year', 'month']).size().reset_index(name='pixel_count')
monthly_counts['availability_pct'] = (monthly_counts['pixel_count'] / max_pixels) * 100

print(f"Average Spatial Coverage: {monthly_counts['availability_pct'].mean():.2f}%")
print(f"Minimum Spatial Coverage: {monthly_counts['availability_pct'].min():.2f}% in {monthly_counts.loc[monthly_counts['availability_pct'].idxmin(), 'year']}")

# Plot Coverage over time
plt.figure(figsize=(12, 4))
plt.plot(monthly_counts.index, monthly_counts['availability_pct'], color='teal')
plt.axhline(y=95, color='r', linestyle='--', label='95% Threshold')
plt.ylabel('Pixel Availability (%)')
plt.xlabel('Months (Sequential)')
plt.title('Temporal Continuity & Data Gap Assessment')
plt.legend()


# ---------------------------------------------------------
# STEP 2: Autocorrelation Analysis
# ---------------------------------------------------------
print("\n--- Step 2: Autocorrelation Analysis ---")

# Create a spatially averaged time series for OISST
ts = df_oisst.groupby('month_index')['sst'].mean()

# Calculate ACF values
acf_values = sm.tsa.stattools.acf(ts, nlags=12)
lag_1 = acf_values[1]
print(f"Autocorrelation at Lag 1: {lag_1:.4f}")

if lag_1 > 0.1:
    print("RESULT: Significant serial correlation detected at Lag 1.")
    print("CONCLUSION: Use Modified Mann-Kendall (MMK) for trend analysis.")
else:
    print("RESULT: No significant serial correlation.")
    print("CONCLUSION: Standard Mann-Kendall is acceptable.")

# ACF Plot
plt.figure(figsize=(10, 5))
plot_acf(ts, lags=36, alpha=0.05)
plt.xlabel('Lag (Months)')
plt.ylabel('Autocorrelation')
plt.title('Autocorrelation Function (ACF) - Bay of Bengal SST')


